generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String         @id @default(uuid())
  telegramId        BigInt         @unique
  telegramUsername  String?
  displayName       String
  role              UserRole       @default(TESTER)
  businessName      String?
  businessType      String?
  companyCR         String?
  preferredLanguage String         @default("ar")
  createdAt         DateTime       @default(now())
  isActive          Boolean        @default(true)
  conversations     Conversation[]
  messages          Message[]

  @@index([telegramId])
  @@index([role])
}

enum UserRole {
  FOUNDER
  TESTER
  SME_OWNER
  PROFESSIONAL
  BLOCKED
}

model Conversation {
  id              String             @id @default(uuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id])
  startedAt       DateTime           @default(now())
  lastMessageAt   DateTime           @default(now())
  status          ConversationStatus @default(OPEN)
  topicSummary    String?
  primaryCategory String?
  messages        Message[]

  @@index([userId])
  @@index([status])
  @@index([lastMessageAt])
}

enum ConversationStatus {
  OPEN
  AWAITING_FOUNDER_REVIEW
  AWAITING_PROFESSIONAL
  RESOLVED
  ESCALATED
}

model Message {
  id                     String           @id @default(uuid())
  conversationId         String
  conversation           Conversation     @relation(fields: [conversationId], references: [id])
  userId                 String
  user                   User             @relation(fields: [userId], references: [id])
  direction              MessageDirection
  contentType            ContentType
  rawContent             String?          @db.Text
  mediaFileId            String?
  mediaLocalPath         String?
  extractedText          String?          @db.Text
  detectedGovernmentBody String?
  detectedCategory       String?
  detectedUrgency        Int?
  detectedDeadline       DateTime?
  detectedAmountSar      Decimal?         @db.Decimal(12, 2)
  aiClassification       Json?
  aiResponseDraft        String?          @db.Text
  aiConfidence           Float?
  aiPromptVersion        String?
  wasSentAutomatically   Boolean          @default(false)
  founderReviewed        Boolean          @default(false)
  founderAction          FounderAction?
  founderEditedResponse  String?          @db.Text
  sentAt                 DateTime?
  createdAt              DateTime         @default(now())

  @@index([conversationId])
  @@index([direction])
  @@index([detectedGovernmentBody])
  @@index([detectedUrgency])
  @@index([createdAt])
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum ContentType {
  TEXT
  PHOTO
  DOCUMENT
  VOICE
}

enum FounderAction {
  APPROVED
  EDITED
  REJECTED
  PENDING
}

model GovernmentBody {
  id                String   @id @default(uuid())
  code              String   @unique
  nameEn            String
  nameAr            String
  description       String   @db.Text
  commonNoticeTypes Json
  typicalUrgency    Int
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
}

model NoticeTypeTemplate {
  id                   String   @id @default(uuid())
  governmentBodyCode   String
  code                 String   @unique
  nameEn               String
  nameAr               String
  description          String   @db.Text
  keywordsAr           String[]
  keywordsEn           String[]
  defaultUrgency       Int
  requiresProfessional Boolean
  typicalDeadlineDays  Int?
  responseTemplateAr   String   @db.Text
  createdAt            DateTime @default(now())

  @@index([governmentBodyCode])
}

model AuditLog {
  id         String   @id @default(uuid())
  eventType  String
  eventData  Json
  userId     String?
  occurredAt DateTime @default(now())

  @@index([eventType])
  @@index([occurredAt])
}

