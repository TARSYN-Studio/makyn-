generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================================================
//  USERS
// ==========================================================================

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  emailVerifiedAt   DateTime?
  passwordHash      String
  fullName          String
  phoneNumber       String?   @unique
  phoneVerifiedAt   DateTime?
  preferredLanguage String    @default("ar")
  role              UserRole  @default(SME_OWNER)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastLoginAt       DateTime?

  memberships         Membership[]
  channels            MessagingChannel[]
  channelTokens       ChannelConnectToken[]
  sessions            Session[]
  conversations       Conversation[]
  messages            Message[]
  issuesCreated       Issue[]               @relation("IssueCreator")
  issuesAssigned      Issue[]               @relation("IssueAssignee")
  issueNotes          IssueNote[]
  documents           CompanyDocument[]
  auditLogActions     AuditLog[]            @relation("AuditActor")
  orgsSoftDeleted     Organization[]        @relation("OrgDeleter")

  @@index([email])
  @@index([phoneNumber])
}

enum UserRole {
  FOUNDER
  TESTER
  SME_OWNER
  PROFESSIONAL
  BLOCKED
}

// ==========================================================================
//  ORGANIZATIONS (DB table stays "Company" PascalCase for one release
//  cycle — URL + model + code surface renamed to Organization; v1.4 is
//  an app-layer rename with deferred DB-level rename)
// ==========================================================================

model Organization {
  id String @id @default(uuid())

  legalNameAr    String
  legalNameEn    String?
  tradeName      String?
  businessType   String?
  ownerLegalName String?

  crNumber     String?   @unique
  crIssueDate  DateTime?
  crExpiryDate DateTime?

  zatcaTin              String? @unique
  vatRegistrationNumber String?
  zakatRegistered       Boolean @default(false)

  gosiEmployerNumber  String? @unique
  qiwaEstablishmentId String? @unique
  molFileNumber       String?
  saudizationCategory String?

  muqeemAccountNumber String?
  moi700Number        String?

  baladyLicenseNumber String?
  baladyLicenseType   String?
  baladyExpiryDate    DateTime?

  primaryBankName          String?
  primaryBankIbanEncrypted String? @db.Text

  notes     String?  @db.Text
  isActive  Boolean  @default(true)

  // Soft-delete — only OWNER role can set. `deletedAt IS NULL` means
  // the org is live. Delete does NOT cascade to related orgs;
  // parent_subsidiary edges flip to status='stale' (v1.5 scope).
  deletedAt        DateTime?
  deletedByUserId  String?
  deletedBy        User?     @relation("OrgDeleter", fields: [deletedByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Chamber of Commerce
  chamberMembershipNumber String?
  chamberMembershipExpiry DateTime?

  // Mudad / WPS
  mudadWpsCompliant   Boolean?
  mudadLastUpdateDate DateTime?

  // Civil Defense
  civilDefenseCertNumber String?
  civilDefenseExpiry     DateTime?

  // Ministry of Industry
  industryLicenseNumber String?
  industryLicenseExpiry DateTime?
  industryActivities    String?   @db.Text

  // SFDA
  sfdaLicenseNumber String?
  sfdaLicenseType   String?
  sfdaLicenseExpiry DateTime?

  // Ministry of Health
  mohLicenseNumber String?
  mohFacilityType  String?
  mohLicenseExpiry DateTime?

  // Ministry of Tourism
  tourismLicenseNumber    String?
  tourismClassification   String?
  tourismLicenseExpiry    DateTime?

  // CST
  cstLicenseNumber String?
  cstServiceType   String?

  // SAMA
  samaLicenseNumber String?
  samaLicenseType   String?

  // CMA
  cmaLicenseNumber String?
  cmaLicenseType   String?

  // MISA
  misaLicenseNumber String?
  misaLicenseExpiry DateTime?

  // SASO
  sasoCertNumber String?

  // Monsha'at
  monshaatRegistrationId String?

  // Professional bodies (SOCPA / SCE)
  professionalBodyMembershipNumber String?
  professionalBodyType             String?

  // Free-form for misc documents
  otherDocuments Json?

  memberships Membership[]
  issues      Issue[]
  messages    Message[]
  documents   CompanyDocument[]
  auditLogs   AuditLog[]

  @@index([crNumber])
  @@index([zatcaTin])
  @@index([gosiEmployerNumber])
  @@index([qiwaEstablishmentId])
  @@index([deletedAt])
  @@map("Company")
}

// ==========================================================================
//  ISSUES
// ==========================================================================

model Issue {
  id             String        @id @default(uuid())
  // Nullable — bot-detected issues in the "needs manual routing" queue
  // (matched identifier ≠ any org the source user is a member of) have
  // no organization until a human routes them. Matcher sets this when
  // confidence is high and membership allows it.
  organizationId String?       @map("companyId")
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // Provenance — replaces the former single `ownerId`.
  // `createdByUserId` is the human who created the row via a forward,
  // a direct add, or a note. Null when purely bot-detected from an
  // inbound channel (the `detectedBy` field carries that signal).
  detectedBy        DetectedBy  @default(HUMAN)
  createdByUserId   String?     @map("ownerId")
  createdBy         User?       @relation("IssueCreator", fields: [createdByUserId], references: [id])
  assignedToUserId  String?
  assignedTo        User?       @relation("IssueAssignee", fields: [assignedToUserId], references: [id])

  // Source + matcher trace for cross-org routing.
  // sourceChannel is the channel the notice arrived on. sourceUserId
  // is the owner of that channel. matchedByIdentifier is the key the
  // matcher keyed on (e.g. "cr_number", "zatca_tin", "unified_number").
  // matchedToOrganizationId records the matcher's output even if the
  // match was rejected (user not a member) so manual routing can see
  // the proposed link.
  sourceChannel              String?
  sourceUserId               String?
  matchedByIdentifier        String?
  matchedToOrganizationId    String?
  matchConfidence            Float?
  needsManualRouting         Boolean      @default(false)

  titleAr   String
  titleEn   String?
  summaryAr String  @db.Text

  governmentBody String
  noticeType     String?
  urgencyLevel   Int

  detectedDeadline  DateTime?
  detectedAmountSar Decimal?  @db.Decimal(12, 2)
  referenceNumber   String?
  extractedEntities Json?

  recommendedAction   String  @db.Text
  recommendedHandler  String?
  actionDeadlineHours Int?
  penaltyIfIgnored    String? @db.Text
  whatToTellHandlerAr String? @db.Text

  status              IssueStatus @default(OPEN)
  resolvedAt          DateTime?
  resolutionNotes     String?     @db.Text
  assignedHandlerName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]
  notes    IssueNote[]

  @@index([organizationId])
  @@index([createdByUserId])
  @@index([assignedToUserId])
  @@index([needsManualRouting])
  @@index([status])
  @@index([urgencyLevel])
  @@index([detectedDeadline])
}

enum DetectedBy {
  HUMAN
  BOT
  INBOUND_TELEGRAM
  INBOUND_EMAIL
  SYSTEM
}

enum IssueStatus {
  OPEN
  ACKNOWLEDGED
  WITH_PROFESSIONAL
  WAITING_GOVERNMENT
  RESOLVED
  ESCALATED
  ARCHIVED
}

model IssueNote {
  id        String   @id @default(uuid())
  issueId   String
  issue     Issue    @relation(fields: [issueId], references: [id])
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([issueId])
}

// ==========================================================================
//  CHANNELS
// ==========================================================================

model MessagingChannel {
  id             String      @id @default(uuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  channelType    ChannelType
  externalId     String
  externalHandle String?
  isActive       Boolean     @default(true)
  connectedAt    DateTime    @default(now())
  lastUsedAt     DateTime?

  @@unique([channelType, externalId])
  @@index([userId])
}

enum ChannelType {
  TELEGRAM
  WHATSAPP
  EMAIL
  SMS
}

model ChannelConnectToken {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  channelType ChannelType
  token       String      @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime    @default(now())

  @@index([token])
}

// ==========================================================================
//  WEB SESSIONS
// ==========================================================================

model Session {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())
  userAgent  String?
  ipAddress  String?

  @@index([userId])
}

// ==========================================================================
//  CONVERSATIONS (kept from v0 — Telegram thread grouping)
// ==========================================================================

model Conversation {
  id              String             @id @default(uuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id])
  startedAt       DateTime           @default(now())
  lastMessageAt   DateTime           @default(now())
  status          ConversationStatus @default(OPEN)
  topicSummary    String?
  primaryCategory String?
  messages        Message[]

  @@index([userId])
  @@index([status])
  @@index([lastMessageAt])
}

enum ConversationStatus {
  OPEN
  AWAITING_FOUNDER_REVIEW
  AWAITING_PROFESSIONAL
  RESOLVED
  ESCALATED
}

// ==========================================================================
//  MESSAGES
// ==========================================================================

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])

  organizationId String?       @map("companyId")
  organization   Organization? @relation(fields: [organizationId], references: [id])
  issueId        String?
  issue          Issue?        @relation(fields: [issueId], references: [id])
  channelType    ChannelType   @default(TELEGRAM)

  identifierMatchAttempted  Boolean @default(false)
  identifierMatchConfidence Float?
  identifierMatchReasoning  String? @db.Text

  direction              MessageDirection
  contentType            ContentType
  rawContent             String?          @db.Text
  mediaFileId            String?
  mediaLocalPath         String?
  extractedText          String?          @db.Text
  detectedGovernmentBody String?
  detectedCategory       String?
  detectedUrgency        Int?
  detectedDeadline       DateTime?
  detectedAmountSar      Decimal?         @db.Decimal(12, 2)
  aiClassification       Json?
  aiExtraction           Json?
  aiAction               Json?
  aiResponseDraft        String?          @db.Text
  aiConfidence           Float?
  aiPromptVersion        String?
  wasSentAutomatically   Boolean          @default(false)
  founderReviewed        Boolean          @default(false)
  founderAction          FounderAction?
  founderEditedResponse  String?          @db.Text
  sentAt                 DateTime?
  createdAt              DateTime         @default(now())

  @@index([conversationId])
  @@index([direction])
  @@index([detectedGovernmentBody])
  @@index([detectedUrgency])
  @@index([createdAt])
  @@index([organizationId])
  @@index([issueId])
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum ContentType {
  TEXT
  PHOTO
  DOCUMENT
  VOICE
}

enum FounderAction {
  APPROVED
  EDITED
  REJECTED
  PENDING
}

// ==========================================================================
//  COMPANY DOCUMENTS (document-driven onboarding)
// ==========================================================================

model CompanyDocument {
  id             String        @id @default(uuid())
  organizationId String?       @map("companyId")
  organization   Organization? @relation(fields: [organizationId], references: [id])
  userId         String
  user           User          @relation(fields: [userId], references: [id])

  docType      DocumentType
  originalName String
  storagePath  String
  mimeType     String
  fileSizeBytes Int

  ocrText               String?          @db.Text
  extractedData         Json?
  extractionVersion     String?
  extractionConfidence  Float?
  extractionStatus      ExtractionStatus @default(PENDING)
  extractionError       String?          @db.Text
  extractionStartedAt   DateTime?
  extractionCompletedAt DateTime?

  sessionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([organizationId])
  @@index([docType])
  @@index([sessionId])
}

enum DocumentType {
  COMMERCIAL_REGISTRATION
  ZATCA_VAT_CERTIFICATE
  ZAKAT_ASSESSMENT
  CHAMBER_OF_COMMERCE
  GOSI_REGISTRATION
  QIWA_ESTABLISHMENT
  MUDAD_CERTIFICATE
  MUQEEM_ACCOUNT
  BALADY_LICENSE
  CIVIL_DEFENSE_CERT
  MINISTRY_OF_INDUSTRY
  MINISTRY_OF_HEALTH
  MINISTRY_OF_TOURISM
  MINISTRY_OF_JUSTICE
  MINISTRY_OF_ENVIRONMENT
  MINISTRY_OF_CULTURE
  MINISTRY_OF_SPORTS
  SFDA_LICENSE
  SASO_CERTIFICATE
  CST_LICENSE
  SAMA_LICENSE
  CMA_LICENSE
  MISA_INVESTMENT_LICENSE
  MONSHAAT_REGISTRATION
  SOCPA_MEMBERSHIP
  SCE_MEMBERSHIP
  MHRSD_NITAQAT
  OTHER
}

enum ExtractionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

// ==========================================================================
//  REFERENCE DATA (seeded)
// ==========================================================================

model GovernmentBody {
  id                String   @id @default(uuid())
  code              String   @unique
  nameEn            String
  nameAr            String
  description       String   @db.Text
  commonNoticeTypes Json
  typicalUrgency    Int
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
}

model NoticeTypeTemplate {
  id                   String   @id @default(uuid())
  governmentBodyCode   String
  code                 String   @unique
  nameEn               String
  nameAr               String
  description          String   @db.Text
  keywordsAr           String[]
  keywordsEn           String[]
  defaultUrgency       Int
  requiresProfessional Boolean
  typicalDeadlineDays  Int?
  responseTemplateAr   String   @db.Text
  createdAt            DateTime @default(now())

  @@index([governmentBodyCode])
}

// ==========================================================================
//  MEMBERSHIPS — v1.4 multi-user: User ↔ Organization join with role.
//  Every existing (companies.owner_id → users.id) pair is backfilled as
//  one Membership row with role=OWNER in the accompanying migration.
// ==========================================================================

model Membership {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  role           OrgRole      @default(MEMBER)
  invitedById    String?
  invitedAt      DateTime     @default(now())
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ==========================================================================
//  AUDIT LOG (v1.4) — polymorphic tier-2: sensitive actions + data writes.
//  `diff` stores {before, after} for writes, null for sensitive-only events
//  (invite sent, role changed, ownership transferred, org deleted).
//  Index supports "show audit events for this org newest-first".
// ==========================================================================

model AuditLog {
  id             String        @id @default(uuid())
  actorUserId    String?
  actorUser      User?         @relation("AuditActor", fields: [actorUserId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  entityType     String
  entityId       String?
  action         String
  diff           Json?
  ip             String?
  userAgent      String?
  timestamp      DateTime      @default(now())

  @@index([organizationId, timestamp(sort: Desc)])
  @@index([entityType, entityId])
  @@index([actorUserId])
}

// Prior AI-pipeline debug log (previously named `AuditLog`). Table
// renamed to `AiEventLog` so the name frees up for the new polymorphic
// AuditLog. Historical rows preserved via ALTER TABLE RENAME.
model AiEventLog {
  id         String   @id @default(uuid())
  eventType  String
  eventData  Json
  userId     String?
  occurredAt DateTime @default(now())

  @@index([eventType])
  @@index([occurredAt])
}

// Idempotency ledger for Telegram webhook updates. We write a row on first
// receipt; the unique constraint on updateId makes retries fail with P2002
// so we can skip re-processing instead of running the pipeline twice.
model TelegramUpdate {
  id         String   @id @default(uuid())
  updateId   BigInt   @unique
  receivedAt DateTime @default(now())

  @@index([receivedAt])
}
