# --- Domains ---
APP_URL=https://app.makyn.site
API_URL=https://api.makyn.site

# --- Database (shared) ---
DATABASE_URL=
DATABASE_CA_CERT_PATH=/etc/ssl/vultr-db-ca.crt

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=MAKYN_BOT
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=
FOUNDER_TELEGRAM_USER_ID=
FOUNDER_ADMIN_CHAT_ID=

# --- AI (OpenAI) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# --- OCR (Google Vision) ---
GOOGLE_APPLICATION_CREDENTIALS=/etc/secrets/gcp-vision.json

# --- Web auth ---
# SESSION_SECRET: 48 random bytes base64 (used for future cookie signing upgrades)
SESSION_SECRET=
# ENCRYPTION_KEY: 32 random bytes base64 (for IBAN encryption at rest)
ENCRYPTION_KEY=

# --- OAuth (Google + Microsoft) ---
# Redirect URIs to register at each provider:
#   {APP_URL}/api/auth/google/callback
#   {APP_URL}/api/auth/microsoft/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Microsoft: register an Entra ID app; use `common` tenant (supports
# personal + work/school accounts).
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- Tuning ---
AUTO_SEND_CONFIDENCE_THRESHOLD=0.85
AUTO_SEND_MAX_URGENCY=3

# --- Runtime ---
NODE_ENV=production
LOG_LEVEL=info
BOT_PORT=8080
WEB_PORT=3000
